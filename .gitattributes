# Normaliza fins de linha para LF ao fazer commit (compatível com Linux/Render)
* text=auto eol=lf

# Arquivos explicitamente texto
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.ini text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.env text eol=lf
*.mako text eol=lf
*.sh text eol=lf

# Arquivos binários — não alterar
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
